{
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Listen for Xdebug",
			"type": "php",
			"request": "launch",
			"port": 9003,
			"pathMappings": {
				"/var/www/html/wp-content/plugins/gutenberg": "${workspaceFolder}"
			}
		},
		{
			"type": "msedge",
			"request": "launch",
			"name": "Launch Vivaldi and debug",
			"url": "http://localhost:8888/",
			"webRoot": "${workspaceFolder}",
			"runtimeExecutable": "/Applications/Vivaldi.app/Contents/MacOS/Vivaldi"
		},
		{
			"type": "node",
			"request": "launch",
			"name": "Debug current e2e test",
			"program": "${workspaceFolder}/node_modules/@wordpress/scripts/bin/wp-scripts.js",
			"args": [
				"test-e2e",
				"--config=${workspaceFolder}/packages/e2e-tests/jest.config.js",
				"--verbose=true",
				"--runInBand",
				"--watch",
				"${file}"
			],
			"console": "integratedTerminal",
			"internalConsoleOptions": "neverOpen",
			"trace": "all"
		}
	]
}
