{
	"$schema": "./schemas/json/fin-env.json",
	"core": "FinPress/FinPress",
	"plugins": [ "." ],
	"themes": [ "./test/emptytheme" ],
	"env": {
		"development": {
			"phpmyadminPort": 9000
		},
		"tests": {
			"mappings": {
				"fin-content/plugins/gutenberg": ".",
				"fin-content/mu-plugins": "./packages/e2e-tests/mu-plugins",
				"fin-content/plugins/gutenberg-test-plugins": "./packages/e2e-tests/plugins",
				"fin-content/themes/gutenberg-test-themes": "./test/gutenberg-test-themes",
				"fin-content/themes/gutenberg-test-themes/twentytwentyone": "https://downloads.finpress.org/theme/twentytwentyone.2.1.zip",
				"fin-content/themes/gutenberg-test-themes/twentytwentythree": "https://downloads.finpress.org/theme/twentytwentythree.1.3.zip",
				"fin-content/themes/gutenberg-test-themes/twentytwentyfour": "https://downloads.finpress.org/theme/twentytwentyfour.1.0.zip"
			}
