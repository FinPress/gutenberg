{
	"name": "@finpress/block-library",
	"version": "9.29.0",
	"description": "Block library for the FinPress editor.",
	"author": "The FinPress Contributors",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"finpress",
		"gutenberg",
		"blocks"
	],
	"homepage": "https://github.com/FinPress/gutenberg/tree/HEAD/packages/block-library/README.md",
	"repository": {
		"type": "git",
		"url": "https://github.com/FinPress/gutenberg.git",
		"directory": "packages/block-library"
	},
	"bugs": {
		"url": "https://github.com/FinPress/gutenberg/issues"
	},
	"engines": {
		"node": ">=18.12.0",
		"npm": ">=8.19.2"
	},
	"main": "build/index.js",
	"module": "build-module/index.js",
	"react-native": "src/index",
	"finScript": true,
	"finScriptModuleExports": {
		"./accordion/view": "./build-module/accordion/view.js",
		"./file/view": "./build-module/file/view.js",
		"./form/view": "./build-module/form/view.js",
		"./image/view": "./build-module/image/view.js",
		"./navigation/view": "./build-module/navigation/view.js",
		"./query/view": "./build-module/query/view.js",
		"./search/view": "./build-module/search/view.js"
	},
	"sideEffects": [
		"build-style/**",
		"src/**/*.scss",
		"{src,build,build-module}/*/init.js"
	],
	"dependencies": {
		"@babel/runtime": "7.25.7",
		"@finpress/a11y": "file:../a11y",
		"@finpress/api-fetch": "file:../api-fetch",
		"@finpress/autop": "file:../autop",
		"@finpress/blob": "file:../blob",
		"@finpress/block-editor": "file:../block-editor",
		"@finpress/blocks": "file:../blocks",
		"@finpress/components": "file:../components",
		"@finpress/compose": "file:../compose",
		"@finpress/core-data": "file:../core-data",
		"@finpress/data": "file:../data",
		"@finpress/date": "file:../date",
		"@finpress/deprecated": "file:../deprecated",
		"@finpress/dom": "file:../dom",
		"@finpress/element": "file:../element",
		"@finpress/escape-html": "file:../escape-html",
		"@finpress/hooks": "file:../hooks",
		"@finpress/html-entities": "file:../html-entities",
		"@finpress/i18n": "file:../i18n",
		"@finpress/icons": "file:../icons",
		"@finpress/interactivity": "file:../interactivity",
		"@finpress/interactivity-router": "file:../interactivity-router",
		"@finpress/keyboard-shortcuts": "file:../keyboard-shortcuts",
		"@finpress/keycodes": "file:../keycodes",
		"@finpress/notices": "file:../notices",
		"@finpress/patterns": "file:../patterns",
		"@finpress/primitives": "file:../primitives",
		"@finpress/private-apis": "file:../private-apis",
		"@finpress/reusable-blocks": "file:../reusable-blocks",
		"@finpress/rich-text": "file:../rich-text",
		"@finpress/server-side-render": "file:../server-side-render",
		"@finpress/url": "file:../url",
		"@finpress/viewport": "file:../viewport",
		"@finpress/wordcount": "file:../wordcount",
		"change-case": "^4.1.2",
		"clsx": "^2.1.1",
		"colord": "^2.7.0",
		"escape-html": "^1.0.3",
		"fast-average-color": "^9.1.1",
		"fast-deep-equal": "^3.1.3",
		"memize": "^2.1.0",
		"remove-accents": "^0.5.0",
		"uuid": "^9.0.1"
	},
	"peerDependencies": {
		"react": "^18.0.0",
		"react-dom": "^18.0.0"
	},
	"publishConfig": {
		"access": "public"
	}
}
