{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "core/stretchy-text",
	"version": "0.1.0",
	"title": "Stretchy Text",
	"category": "text",
	"icon": "text",
	"description": "Text that expands to fill the width of its container.",
	"example": {},
	"textdomain": "default",
	"attributes": {
		"content": {
			"type": "rich-text",
			"source": "rich-text",
			"selector": "svg > foreignObject > span"
		},
		"viewBox": {
			"type": "string"
		}
	},
	"supports": {
		"reusable": false,
		"html": false,
		"color": {
			"gradients": true,
			"link": true,
			"__experimentalDefaultControls": {
				"background": true,
				"text": true
			}
		},
		"typography": {
			"__experimentalFontFamily": true,
			"__experimentalFontWeight": true,
			"__experimentalFontStyle": true,
			"__experimentalTextTransform": true,
			"__experimentalTextDecoration": true,
			"__experimentalLetterSpacing": true,
			"__experimentalDefaultControls": {
				"fontSize": true
			}
		},
		"__experimentalBorder": {
			"radius": true
		}
	},
	"style": "wp-block-stretchy-text"
}
