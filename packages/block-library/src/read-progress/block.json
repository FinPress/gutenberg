{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "core/read-progress",
	"category": "theme",
	"title": "Read Progress",
	"description": "Displays a read progress. Useful for tracking read progress.",
	"textdomain": "default",
	"attributes": {
		"backgroundColor": {
			"type": "string",
			"default": "#f0f0f0"
		},
		"progressColor": {
			"type": "string",
			"default": "#1E1E1E"
		},
		"height": {
			"type": "number",
			"default": 15
		},
		"position": {
			"type": "string",
			"default": "top"
		}
	},
	"supports": {
		"html": false,
		"interactivity": true
	},
	"style": "wp-block-read-progress"
}
