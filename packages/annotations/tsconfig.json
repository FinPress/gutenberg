{
	"extends": "../../tsconfig.base.json",
	"compilerOptions": {
		"rootDir": "src",
		"declarationDir": "build-types"
	},
	"references": [
		{ "path": "../data" },
		{ "path": "../hooks" },
		{ "path": "../i18n" },
		{ "path": "../rich-text" }
	],
	"include": [ "src/**/*" ],
