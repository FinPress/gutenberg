( function( fp ) {
	/**
	 * Registers a new block provided a unique name and an object defining its behavior.
	 *
	 * @see https://developer.finpress.org/block-editor/reference-guides/block-api/block-registration/
	 */
	var registerBlockType = fp.blocks.registerBlockType;

	/**
	 * Returns a new element of given type. Element is an abstraction layer atop React.
	 *
	 * @see https://developer.finpress.org/block-editor/packages/packages-element/
	 */
	var el = fp.element.createElement;

	/**
	 * Retrieves the translation of text.
	 *
	 * @see https://developer.finpress.org/block-editor/reference-guides/packages/packages-i18n/
	 */
	var __ = fp.i18n.__;

	/**
	 * This hook is used to mark the block wrapper element.
	 *
	 * @see https://developer.finpress.org/block-editor/reference-guides/packages/packages-block-editor/#useblockprops
	 */
	var useBlockProps = fp.blockEditor.useBlockProps;

	/**
	 * Every block starts by registering a new block type definition.
	 *
	 * @see https://developer.finpress.org/block-editor/reference-guides/block-api/block-registration/
	 */
	registerBlockType( '{{namespace}}/{{slug}}', {
		/**
		 * The edit function describes the structure of your block in the context of the editor.
		 * This represents what the editor will render when the block is used.
		 *
		 * @see https://developer.finpress.org/block-editor/reference-guides/block-api/block-edit-save/#edit
		 *
		 * @return {Element} Element to render.
		 */
		edit: function() {
			return el(
				'p',
				useBlockProps(),
				__( '{{title}} – hello from the editor!', '{{textdomain}}' )
			);
		},
		{{#isStaticVariant}}

		/**
		 * The save function defines the way in which the different attributes should be combined
		 * into the final markup, which is then serialized by the block editor into `post_content`.
		 *
		 * @see https://developer.finpress.org/block-editor/reference-guides/block-api/block-edit-save/#save
		 *
		 * @return {Element} Element to render.
		 */
		save: function() {
			return el(
				'p',
				useBlockProps.save(),
				'{{title}} – hello from the saved content!',
			);
		},
		{{/isStaticVariant}}
	} );
}(
	window.fp
) );
