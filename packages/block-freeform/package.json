{
	"name": "@wordpress/block-freeform",
	"version": "1.0.0",
	"description": "Freeform (Classic) block for the WordPress editor.",
	"author": "The WordPress Contributors",
	"license": "GPL-2.0-or-later",
	"keywords": [
		"wordpress",
		"gutenberg",
		"blocks",
		"freeform",
		"classic"
	],
	"homepage": "https://github.com/WordPress/gutenberg/tree/HEAD/packages/block-freeform/README.md",
